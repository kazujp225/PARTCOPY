{
  "name": "partcopy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:worker\" \"npm run dev:client\"",
    "dev:client": "PARTCOPY_API_PORT=${PARTCOPY_API_PORT:-3002} vite --host 127.0.0.1 --port ${PARTCOPY_CLIENT_PORT:-5180}",
    "dev:server": "PARTCOPY_API_PORT=${PARTCOPY_API_PORT:-3002} tsx watch server/index.ts",
    "dev:worker": "tsx watch server/worker.ts",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase migration up",
    "backfill:dom": "tsx scripts/backfill-dom-snapshots.ts",
    "build": "tsc -b && vite build",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "puppeteer": "^23.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
